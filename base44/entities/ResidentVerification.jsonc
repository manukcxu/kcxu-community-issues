{
  "name": "ResidentVerification",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "es",
        "vi",
        "zh",
        "tl"
      ],
      "default": "en"
    },
    "declared": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "phone"
  ]
}